---
import Layout from '../../layouts/Layout.astro';
import AsciiPattern from '../../components/AsciiPattern.astro';

const heroArt = [
  ' [#+#+#]  {^_^}  [#+#+#]  {^_^}  [#+#+#] ',
  ' |#+#+#|  |~|~|  |#+#+#|  |~|~|  |#+#+#| ',
  ' [#+#+#]  {v-v}  [#+#+#]  {v-v}  [#+#+#] ',
  '  =====   =====   =====   =====   =====  ',
];

const homeArt = [
  '  🏠  🛡️  🏠  🛡️  🏠  🛡️  🏠  ',
  ' /^\\ /^\\ /^\\ /^\\ /^\\ /^\\ /^\\ ',
  ' ||| ||| ||| ||| ||| ||| ||| ',
];

const footerArt = [
  ' <[#]>  {X}  <[#]>  {X}  <[#]> ',
  ' |||||  |||  |||||  |||  ||||| ',
  '  ===    ==   ===    ==   ===   ',
];
---

<Layout title="🤝 Seguridad y Prosperidad - Iván Cepeda 2026" description="Orden con dignidad: seguridad humana, empleo, salud, educación y austeridad republicana para la prosperidad de todos.">
  <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12 relative overflow-hidden">

    <!-- Fondo Hogar Seguro -->
    <div class="absolute inset-0 pointer-events-none opacity-10 z-0" aria-hidden="true">
      <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-blue-950 via-slate-950 to-indigo-950"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 40%, rgba(59,130,246,0.08) 0%, transparent 50%), radial-gradient(ellipse at 30% 80%, rgba(99,102,241,0.06) 0%, transparent 50%);"></div>
    </div>

    <AsciiPattern lines={heroArt} colors={['text-eje-safety', 'text-sky-300', 'text-amber-300', 'text-rose-200', 'text-ph-light']} wrapperClass="mb-6" textClass="text-[9px] sm:text-xs md:text-sm" blockClass="gap-1" />

    <div class="mb-8 relative z-10">
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 text-sky-300 hover:text-sky-100 font-bold transition-colors bg-sky-950/50 border border-sky-500/30 px-4 py-2 rounded-full hover:bg-sky-900/60 text-sm">
        🏠 ← Volver al Inicio
      </a>
    </div>

    <!-- HERO: Hogar Seguro -->
    <header class="relative z-10 mb-16">
      <div class="relative bg-gradient-to-br from-sky-900/70 via-blue-950/80 to-indigo-900/70 border-4 border-sky-400/40 rounded-3xl p-6 sm:p-10 shadow-[0_0_60px_rgba(59,130,246,0.15)] overflow-hidden">
        <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
          <span class="absolute top-3 left-[8%] text-3xl animate-bounce opacity-40" style="animation-duration:2s">🏠</span>
          <span class="absolute top-8 right-[15%] text-4xl animate-pulse opacity-30" style="animation-duration:2s">🛡️</span>
          <span class="absolute bottom-10 left-[18%] text-3xl animate-spin opacity-25" style="animation-duration:8s">💼</span>
          <span class="absolute top-1/3 right-[6%] text-5xl animate-bounce opacity-20" style="animation-duration:3s;animation-delay:0.4s">🤝</span>
          <span class="absolute bottom-8 right-[22%] text-2xl animate-pulse opacity-35" style="animation-duration:1.8s">🏥</span>
        </div>

        <div class="relative">
          <h1 class="text-4xl sm:text-6xl md:text-7xl font-black uppercase mb-6 text-transparent bg-clip-text bg-gradient-to-r from-sky-200 via-blue-300 to-indigo-200 font-['Impact'] tracking-wider leading-tight">
            🤝 Seguridad y Prosperidad
          </h1>
          <p class="text-xl sm:text-2xl text-sky-100 font-['Comic_Sans_MS',cursive] leading-relaxed max-w-3xl">
            La verdadera seguridad no se basa en represión, sino en la <strong class="text-white">certeza de tener techo, empleo, salud y un Estado que funciona</strong>. 
            Austeridad republicana, no neoliberal. <strong class="text-sky-200">Orden con dignidad para todas y todos.</strong>
            <span class="inline-block animate-pulse">🏰</span>
          </p>
        </div>
      </div>
    </header>

    <!-- STORYTELLING: La Muralla de la Dignidad -->
    <section class="relative z-10 mb-16 bg-gradient-to-r from-blue-950/30 via-slate-950/40 to-indigo-950/30 border-2 border-dashed border-sky-500/30 rounded-3xl p-6 sm:p-8">
      <AsciiPattern lines={homeArt} colors={['text-sky-300', 'text-blue-400', 'text-amber-300']} wrapperClass="mb-6" textClass="text-[10px] sm:text-sm" blockClass="gap-1" />

      <h2 class="text-2xl sm:text-3xl font-bold text-sky-200 mb-6 font-serif text-center">🏰 La Muralla de la Dignidad: Cada Pilar Sostiene un Derecho</h2>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 mb-8">
        <div class="text-center group">
          <div class="text-5xl mb-2 group-hover:animate-bounce transition-transform">💼</div>
          <div class="text-lg font-bold text-sky-200">Trabajo</div>
          <p class="text-sky-50/60 text-xs mt-1">Salario vital, reforma laboral, empleo juvenil</p>
        </div>
        <div class="text-center group">
          <div class="text-5xl mb-2 group-hover:animate-pulse transition-transform">🏥</div>
          <div class="text-lg font-bold text-blue-200">Salud</div>
          <p class="text-blue-50/60 text-xs mt-1">Derecho, no negocio. 10,000 equipos de atención</p>
        </div>
        <div class="text-center group">
          <div class="text-5xl mb-2 group-hover:animate-bounce transition-transform">📚</div>
          <div class="text-lg font-bold text-indigo-200">Educación</div>
          <p class="text-indigo-50/60 text-xs mt-1">Pública, gratuita y en los territorios</p>
        </div>
        <div class="text-center group">
          <div class="text-5xl mb-2 group-hover:animate-pulse transition-transform">🎭</div>
          <div class="text-lg font-bold text-violet-200">Cultura</div>
          <p class="text-violet-50/60 text-xs mt-1">Arte y memoria para la paz</p>
        </div>
      </div>

      <p class="text-sky-50/80 text-center text-lg font-sans leading-relaxed max-w-2xl mx-auto">
        La "mano dura" nunca trajo paz. La <strong class="text-white">Seguridad Humana</strong> articula políticas sociales, ambientales y de protección. 
        Dar empleo a un joven es en sí mismo una política de seguridad. La paz trae seguridad.
      </p>
    </section>

    <!-- PORTAFOLIO DE SUBPÁGINAS -->
    <section class="relative z-10 mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-sky-200 mb-8 text-center font-['Impact'] tracking-wider flex items-center justify-center gap-3">
        <span class="animate-bounce">🛡️</span> Pilares de la Seguridad y la Prosperidad <span class="animate-bounce">💼</span>
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        <!-- Austeridad -->
        <a href={import.meta.env.BASE_URL + 'ejes/seguridad/austeridad'} class="group block relative bg-gradient-to-b from-blue-950/80 to-slate-950/90 border-3 border-blue-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-blue-500/20 hover:border-blue-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">✂️</div>
          <div class="text-5xl mb-3 group-hover:animate-bounce relative z-10">🛡️</div>
          <h3 class="text-xl font-bold text-blue-200 mb-2 font-['Impact']">El Cinturón Apretado</h3>
          <p class="text-blue-50/70 text-sm leading-relaxed">Austeridad Republicana: recorte de privilegios, cada peso al gasto social.</p>
          <span class="inline-block mt-3 text-xs text-blue-400 group-hover:text-blue-200 transition-colors">💼 Explorar →</span>
        </a>

        <!-- Humana -->
        <a href={import.meta.env.BASE_URL + 'ejes/seguridad/humana'} class="group block relative bg-gradient-to-b from-indigo-950/80 to-violet-950/90 border-3 border-indigo-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-indigo-500/20 hover:border-indigo-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🏰</div>
          <div class="text-5xl mb-3 group-hover:animate-pulse relative z-10">🏰</div>
          <h3 class="text-xl font-bold text-indigo-200 mb-2 font-['Impact']">La Muralla de la Dignidad</h3>
          <p class="text-indigo-50/70 text-sm leading-relaxed">Seguridad Humana no militarista. Protección con justicia social.</p>
          <span class="inline-block mt-3 text-xs text-indigo-400 group-hover:text-indigo-200 transition-colors">🤝 Explorar →</span>
        </a>

        <!-- Salud NUEVA -->
        <a href={import.meta.env.BASE_URL + 'ejes/seguridad/salud'} class="group block relative bg-gradient-to-b from-emerald-950/80 to-green-950/90 border-3 border-emerald-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-emerald-500/20 hover:border-emerald-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🏥</div>
          <div class="text-5xl mb-3 group-hover:animate-bounce relative z-10">🏥</div>
          <h3 class="text-xl font-bold text-emerald-200 mb-2 font-['Impact']">Salud: Derecho 🆕</h3>
          <p class="text-emerald-50/70 text-sm leading-relaxed">10,000 equipos, 7.5M hogares, SISPI. Superar la Ley 100.</p>
          <span class="inline-block mt-3 text-xs text-emerald-400 group-hover:text-emerald-200 transition-colors">💊 Explorar →</span>
        </a>

        <!-- Educación NUEVA -->
        <a href={import.meta.env.BASE_URL + 'ejes/seguridad/educacion'} class="group block relative bg-gradient-to-b from-amber-950/80 to-orange-950/90 border-3 border-amber-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-amber-500/20 hover:border-amber-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">📚</div>
          <div class="text-5xl mb-3 group-hover:animate-spin relative z-10" style="animation-duration:4s">📚</div>
          <h3 class="text-xl font-bold text-amber-200 mb-2 font-['Impact']">Educación Pública 🆕</h3>
          <p class="text-amber-50/70 text-sm leading-relaxed">Universidades en territorios, SEIP, ICETEX transformado. Educación para la paz.</p>
          <span class="inline-block mt-3 text-xs text-amber-400 group-hover:text-amber-200 transition-colors">🎓 Explorar →</span>
        </a>

        <!-- Salario Vital NUEVA -->
        <a href={import.meta.env.BASE_URL + 'ejes/seguridad/salario-vital'} class="group block relative bg-gradient-to-b from-rose-950/80 to-pink-950/90 border-3 border-rose-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-rose-500/20 hover:border-rose-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden sm:col-span-2 lg:col-span-2">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">💰</div>
          <div class="text-5xl mb-3 group-hover:animate-bounce relative z-10">💰</div>
          <h3 class="text-xl font-bold text-rose-200 mb-2 font-['Impact']">Salario Vital y Trabajo Digno 🆕</h3>
          <p class="text-rose-50/70 text-sm leading-relaxed">Reforma laboral consolidada, pensional defendida, formalización del empleo. Economía popular y solidaria.</p>
          <span class="inline-block mt-3 text-xs text-rose-400 group-hover:text-rose-200 transition-colors">💪 Explorar →</span>
        </a>

        <!-- Vivienda NUEVA -->
        <a href={import.meta.env.BASE_URL + 'ejes/seguridad/vivienda'} class="group block relative bg-gradient-to-b from-teal-950/80 to-cyan-950/90 border-3 border-teal-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-teal-500/20 hover:border-teal-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden sm:col-span-2 lg:col-span-2">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🏘️</div>
          <div class="text-5xl mb-3 group-hover:animate-pulse relative z-10">🏘️</div>
          <h3 class="text-xl font-bold text-teal-200 mb-2 font-['Impact']">Vivienda y Hábitat Digno 🆕</h3>
          <p class="text-teal-50/70 text-sm leading-relaxed">Programa masivo de vivienda para jóvenes y familias. Contratación comunitaria para obras públicas.</p>
          <span class="inline-block mt-3 text-xs text-teal-400 group-hover:text-teal-200 transition-colors">🏠 Explorar →</span>
        </a>
      </div>
    </section>

    <!-- DATOS DUROS -->
    <section class="relative z-10 mb-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        <div class="bg-gradient-to-b from-green-950/60 to-emerald-950/60 border-2 border-green-500/20 rounded-2xl p-6 text-center hover:border-green-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">🏥</div>
          <div class="text-4xl font-black text-green-300">10K</div>
          <p class="text-green-100/80 mt-2 text-sm">Equipos básicos de atención en salud desplegados</p>
        </div>
        <div class="bg-gradient-to-b from-sky-950/60 to-blue-950/60 border-2 border-sky-500/20 rounded-2xl p-6 text-center hover:border-sky-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">👵</div>
          <div class="text-4xl font-black text-sky-300">1.1M</div>
          <p class="text-sky-100/80 mt-2 text-sm">Adultos mayores beneficiados con Colombia Mayor duplicado</p>
        </div>
        <div class="bg-gradient-to-b from-amber-950/60 to-orange-950/60 border-2 border-amber-500/20 rounded-2xl p-6 text-center hover:border-amber-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">📈</div>
          <div class="text-4xl font-black text-amber-300">2.5M</div>
          <p class="text-amber-100/80 mt-2 text-sm">Nuevos empleos creados durante el gobierno del cambio</p>
        </div>
      </div>
    </section>

    <!-- CITA ÉPICA -->
    <blockquote class="relative z-10 my-12 bg-gradient-to-r from-blue-950/60 via-indigo-950/40 to-blue-950/60 border-l-4 border-sky-400 p-6 sm:p-8 rounded-r-2xl shadow-xl">
      <div class="absolute -top-4 -left-4 text-5xl">🕊️</div>
      <p class="text-xl sm:text-2xl italic text-white font-medium leading-relaxed font-serif">
        "La verdadera seguridad no se basa solo en represión, sino en la certeza de tener techo, empleo, salud y 
        <strong class="text-sky-200">un Estado que funciona y protege a su gente</strong>. La mayor seguridad se logra cuando hay paz, 
        y cuando el Estado se reconcilia con la ciudadanía."
      </p>
      <footer class="mt-4 text-sky-300 text-sm font-sans">— Iván Cepeda, Programa de Gobierno 2026-2030</footer>
    </blockquote>

    <!-- MARQUEE -->
    <div class="relative z-10 mb-12 bg-black/30 border-2 border-dashed border-sky-500/40 rounded-xl p-4 overflow-hidden">
      <p class="text-sky-200 font-mono text-sm sm:text-base" style="overflow-x:auto">
        <span class="inline-block mr-8">🏠 La paz trae seguridad 🏠</span>
        <span class="inline-block mr-8">💼 Empleo digno es seguridad 💼</span>
        <span class="inline-block mr-8">🛡️ Quien debe apretarse el cinturón es el gobierno 🛡️</span>
        <span class="inline-block mr-8">🏥 La salud no es un negocio, es un derecho 🏥</span>
        <span class="inline-block mr-8">📚 Educación pública para la libertad 📚</span>
      </p>
    </div>

    <!-- CIERRE -->
    <section class="relative z-10 mt-12 flex flex-col items-center text-center">
      <AsciiPattern lines={footerArt} colors={['text-sky-300', 'text-amber-300', 'text-eje-safety', 'text-rose-200']} wrapperClass="mb-6" textClass="text-[9px] xs:text-[10px] sm:text-xs md:text-sm" blockClass="gap-2" />
      <div class="text-6xl mb-4 hover:animate-spin cursor-default">🤝</div>
      <p class="text-xl font-bold text-sky-200 font-sans">
        "La seguridad humana no es debilidad: <br/> es la verdadera fortaleza de una nación que cuida a su gente."
      </p>
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 mt-8 bg-sky-700 hover:bg-sky-600 text-white px-6 py-3 rounded-full font-bold text-lg transition-all transform hover:scale-105 shadow-lg shadow-sky-500/30">
        🏠 Ir al Inicio
      </a>
    </section>

  </div>
</Layout>