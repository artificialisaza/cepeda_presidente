---
import Layout from '../../layouts/Layout.astro';
import AsciiPattern from '../../components/AsciiPattern.astro';

const heroArt = [
  ' <(+)>  {*}  <(+)>  {*}  <(+)>  {*}  <(+)> ',
  ' /| |\\  |||  /| |\\  |||  /| |\\  |||  /| |\\',
  ' \\| |/  |||  \\| |/  |||  \\| |/  |||  \\| |/ ',
  '  [~]   [*]   [~]   [*]   [~]   [*]   [~]  ',
];

const carnivalArt = [
  '  🎭  🎨  🎭  🎨  🎭  🎨  🎭  🎨  🎭  ',
  ' ✊🏾 🪘 ✊🏾 🪘 ✊🏾 🪘 ✊🏾 🪘 ✊🏾 🪘 ',
  '  🎵  💃🏾  🎵  💃🏾  🎵  💃🏾  🎵  💃🏾  ',
];

const footerArt = [
  ' (o@o)  *o*  (o@o)  *o*  (o@o)  *o* ',
  '  |||   |||   |||   |||   |||   |||   ',
  '  ~~~   ~~~   ~~~   ~~~   ~~~   ~~~   ',
];
---

<Layout title="✊🏾 Igualdad y Antirracismo - Iván Cepeda 2026" description="Superación de la pobreza, igualdad sustantiva y reconocimiento pleno a la diversidad colombiana.">
  <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12 relative overflow-hidden">

    <!-- Fondo Carnaval -->
    <div class="absolute inset-0 pointer-events-none opacity-10 z-0" aria-hidden="true">
      <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-pink-950 via-purple-950 to-orange-950"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 30%, rgba(236,72,153,0.08) 0%, transparent 50%), radial-gradient(ellipse at 70% 60%, rgba(249,115,22,0.06) 0%, transparent 50%);"></div>
    </div>

    <AsciiPattern lines={heroArt} colors={['text-eje-equal', 'text-fuchsia-300', 'text-orange-300', 'text-purple-300', 'text-sky-300']} wrapperClass="mb-6" textClass="text-[9px] sm:text-xs md:text-sm" blockClass="gap-1" />

    <div class="mb-8 relative z-10">
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 text-pink-300 hover:text-pink-100 font-bold transition-colors bg-pink-950/50 border border-pink-500/30 px-4 py-2 rounded-full hover:bg-pink-900/60 text-sm">
        🏠 ← Volver al Inicio
      </a>
    </div>

    <!-- HERO: Carnaval vibrante -->
    <header class="relative z-10 mb-16">
      <div class="relative bg-gradient-to-br from-pink-900/70 via-purple-950/80 to-orange-900/70 border-4 border-pink-400/40 rounded-3xl p-6 sm:p-10 shadow-[0_0_60px_rgba(236,72,153,0.15)] overflow-hidden">
        <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
          <span class="absolute top-2 left-[8%] text-3xl animate-bounce opacity-40" style="animation-duration:1.5s">🪘</span>
          <span class="absolute top-8 right-[12%] text-4xl animate-pulse opacity-30" style="animation-duration:2s">✊🏾</span>
          <span class="absolute bottom-10 left-[15%] text-3xl animate-spin opacity-25" style="animation-duration:6s">🎨</span>
          <span class="absolute top-1/3 right-[6%] text-5xl animate-bounce opacity-20" style="animation-duration:2.5s;animation-delay:0.3s">💃🏾</span>
          <span class="absolute bottom-6 right-[20%] text-2xl animate-pulse opacity-35" style="animation-duration:1.8s">🎵</span>
          <span class="absolute top-20 left-[35%] text-4xl animate-bounce opacity-20" style="animation-duration:2.2s;animation-delay:0.8s">🌊</span>
        </div>

        <div class="relative">
          <h1 class="text-4xl sm:text-6xl md:text-7xl font-black uppercase mb-6 text-transparent bg-clip-text bg-gradient-to-r from-pink-200 via-orange-300 to-purple-200 font-['Impact'] tracking-wider leading-tight">
            ✊🏾 Igualdad y Antirracismo
          </h1>
          <p class="text-xl sm:text-2xl text-pink-100 font-['Comic_Sans_MS',cursive] leading-relaxed max-w-3xl">
            Colombia es una <strong class="text-white">nación plural</strong>. La diversidad no es amenaza: es nuestra mayor riqueza. 
            Superar la pobreza, derrotar el racismo y desmontar el patriarcado es la revolución social que nos debemos. 
            <span class="inline-block animate-pulse">🌈</span>
          </p>
        </div>
      </div>
    </header>

    <!-- STORYTELLING: El Carnaval de la Diversidad -->
    <section class="relative z-10 mb-16 bg-gradient-to-r from-pink-950/30 via-purple-950/40 to-orange-950/30 border-2 border-dashed border-pink-500/30 rounded-3xl p-6 sm:p-8">
      <AsciiPattern lines={carnivalArt} colors={['text-pink-300', 'text-orange-300', 'text-purple-300']} wrapperClass="mb-6" textClass="text-[10px] sm:text-sm" blockClass="gap-1" />

      <h2 class="text-2xl sm:text-3xl font-bold text-pink-200 mb-6 font-serif text-center">🎭 El Carnaval de la Diversidad: Colombia Somos Todxs</h2>

      <div class="flex flex-wrap justify-center items-center gap-3 sm:gap-5 text-2xl sm:text-4xl mb-8">
        <span class="hover:scale-150 transition-transform cursor-default animate-bounce" style="animation-duration:1.3s">👩🏽‍🦱</span>
        <span class="text-pink-400">+</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-pulse" style="animation-duration:1.7s">👨🏾‍🦱</span>
        <span class="text-pink-400">+</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-bounce" style="animation-duration:1.5s">👩🏽‍🌾</span>
        <span class="text-pink-400">+</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-pulse" style="animation-duration:2s">🧑🏼‍🦰</span>
        <span class="text-pink-400">+</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-bounce" style="animation-duration:1.6s">👵🏾</span>
        <span class="text-pink-400">+</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-pulse" style="animation-duration:1.9s">🧒🏽</span>
        <span class="text-pink-400">=</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-spin" style="animation-duration:4s">🇨🇴</span>
      </div>

      <p class="text-pink-50/80 text-center text-lg font-sans leading-relaxed max-w-2xl mx-auto">
        Somos afro, indígenas, campesinos, mestizos, urbanos, LGBTIQ+, jóvenes, mujeres, adultos mayores. 
        <strong class="text-white">Ningún país con niveles extremos de desigualdad puede aspirar a avanzar.</strong> 
        La igualdad sustantiva es el centro de nuestra política social.
      </p>
    </section>

    <!-- PORTAFOLIO DE SUBPÁGINAS -->
    <section class="relative z-10 mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-pink-200 mb-8 text-center font-['Impact'] tracking-wider flex items-center justify-center gap-3">
        <span class="animate-bounce">✊🏾</span> Frentes de la Revolución Social <span class="animate-bounce">🌈</span>
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
        <!-- Urbana -->
        <a href={import.meta.env.BASE_URL + 'ejes/igualdad/urbana'} class="group block relative bg-gradient-to-b from-blue-950/80 to-indigo-950/90 border-3 border-blue-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-blue-500/20 hover:border-blue-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🏙️</div>
          <div class="text-5xl mb-3 group-hover:animate-bounce relative z-10">🏙️</div>
          <h3 class="text-xl font-bold text-blue-200 mb-2 font-['Impact']">La Ciudad que Florece</h3>
          <p class="text-blue-50/70 text-sm leading-relaxed">Vivienda digna, servicios públicos, fiscalidad progresiva en los barrios populares.</p>
          <span class="inline-block mt-3 text-xs text-blue-400 group-hover:text-blue-200 transition-colors">🏗️ Explorar →</span>
        </a>

        <!-- Antirracismo -->
        <a href={import.meta.env.BASE_URL + 'ejes/igualdad/antirracismo'} class="group block relative bg-gradient-to-b from-pink-950/80 to-purple-950/90 border-3 border-pink-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-pink-500/20 hover:border-pink-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🪘</div>
          <div class="text-5xl mb-3 group-hover:animate-spin relative z-10" style="animation-duration:3s">🪘</div>
          <h3 class="text-xl font-bold text-pink-200 mb-2 font-['Impact']">El Tambor de la Libertad</h3>
          <p class="text-pink-50/70 text-sm leading-relaxed">Reconocimiento territorial, educación decolonial, fin del racismo estructural.</p>
          <span class="inline-block mt-3 text-xs text-pink-400 group-hover:text-pink-200 transition-colors">🔥 Explorar →</span>
        </a>

        <!-- Mujeres -->
        <a href={import.meta.env.BASE_URL + 'ejes/igualdad/mujeres'} class="group block relative bg-gradient-to-b from-rose-950/80 to-fuchsia-950/90 border-3 border-rose-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-rose-500/20 hover:border-rose-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🙋🏾‍♀️</div>
          <div class="text-5xl mb-3 group-hover:animate-pulse relative z-10">🙋🏾‍♀️</div>
          <h3 class="text-xl font-bold text-rose-200 mb-2 font-['Impact']">Tejedoras de la Vida</h3>
          <p class="text-rose-50/70 text-sm leading-relaxed">Paridad, Sistema Nacional de Cuidado, erradicación de la violencia patriarcal.</p>
          <span class="inline-block mt-3 text-xs text-rose-400 group-hover:text-rose-200 transition-colors">🧶 Explorar →</span>
        </a>

        <!-- Juventud -->
        <a href={import.meta.env.BASE_URL + 'ejes/igualdad/juventud'} class="group block relative bg-gradient-to-b from-purple-950/80 to-fuchsia-950/90 border-3 border-purple-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-purple-500/20 hover:border-purple-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">✊🔥</div>
          <div class="text-5xl mb-3 group-hover:animate-bounce relative z-10">✊🔥</div>
          <h3 class="text-xl font-bold text-purple-200 mb-2 font-['Impact']">La Chispa del Cambio</h3>
          <p class="text-purple-50/70 text-sm leading-relaxed">Educación como derecho, trabajo digno juvenil, fin a la estigmatización.</p>
          <span class="inline-block mt-3 text-xs text-purple-400 group-hover:text-purple-200 transition-colors">🚀 Explorar →</span>
        </a>

        <!-- Territorios Afro -->
        <a href={import.meta.env.BASE_URL + 'ejes/igualdad/territorios-afro'} class="group block relative bg-gradient-to-b from-orange-950/80 to-amber-950/90 border-3 border-orange-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-orange-500/20 hover:border-orange-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🌊</div>
          <div class="text-5xl mb-3 group-hover:animate-pulse relative z-10">🌊</div>
          <h3 class="text-xl font-bold text-orange-200 mb-2 font-['Impact']">Pacífico es Vida</h3>
          <p class="text-orange-50/70 text-sm leading-relaxed">Tumaco, Buenaventura, Puerto Tejada: desarrollo afro con dignidad territorial.</p>
          <span class="inline-block mt-3 text-xs text-orange-400 group-hover:text-orange-200 transition-colors">🏝️ Explorar →</span>
        </a>

        <!-- Pueblos Indígenas NUEVO -->
        <a href={import.meta.env.BASE_URL + 'ejes/igualdad/pueblos-indigenas'} class="group block relative bg-gradient-to-b from-emerald-950/80 to-green-950/90 border-3 border-emerald-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-emerald-500/20 hover:border-emerald-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🪶</div>
          <div class="text-5xl mb-3 group-hover:animate-spin relative z-10" style="animation-duration:4s">🪶</div>
          <h3 class="text-xl font-bold text-emerald-200 mb-2 font-['Impact']">Pueblos Indígenas 🆕</h3>
          <p class="text-emerald-50/70 text-sm leading-relaxed">Autonomía territorial, SEIP, SISPI, Decreto 1275. Contra el etnocidio.</p>
          <span class="inline-block mt-3 text-xs text-emerald-400 group-hover:text-emerald-200 transition-colors">🏔️ Explorar →</span>
        </a>
      </div>
    </section>

    <!-- DATOS DUROS -->
    <section class="relative z-10 mb-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        <div class="bg-gradient-to-b from-pink-950/60 to-purple-950/60 border-2 border-pink-500/20 rounded-2xl p-6 text-center hover:border-pink-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">📊</div>
          <div class="text-4xl font-black text-pink-300">17M</div>
          <p class="text-pink-100/80 mt-2 text-sm">Personas bajo línea de pobreza monetaria</p>
        </div>
        <div class="bg-gradient-to-b from-orange-950/60 to-amber-950/60 border-2 border-orange-500/20 rounded-2xl p-6 text-center hover:border-orange-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">👩🏽‍🦱</div>
          <div class="text-4xl font-black text-orange-300">70%</div>
          <p class="text-orange-100/80 mt-2 text-sm">Trabajo de cuidado no remunerado recae en mujeres</p>
        </div>
        <div class="bg-gradient-to-b from-red-950/60 to-rose-950/60 border-2 border-red-500/20 rounded-2xl p-6 text-center hover:border-red-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">⚠️</div>
          <div class="text-4xl font-black text-red-300">~40</div>
          <p class="text-red-100/80 mt-2 text-sm">Pueblos indígenas en peligro de extinción</p>
        </div>
      </div>
    </section>

    <!-- CITA ÉPICA -->
    <blockquote class="relative z-10 my-12 bg-gradient-to-r from-pink-950/60 via-purple-950/40 to-orange-950/60 border-l-4 border-pink-400 p-6 sm:p-8 rounded-r-2xl shadow-xl">
      <div class="absolute -top-4 -left-4 text-5xl">🔥</div>
      <p class="text-xl sm:text-2xl italic text-white font-medium leading-relaxed font-serif">
        "Debemos acabar con el machismo, el racismo, el desprecio a los pobres, la indiferencia frente a la vida 
        mediante una <strong class="text-pink-200">transformación cultural profunda</strong>. La Revolución Ética es antirracista y antipatriarcal."
      </p>
      <footer class="mt-4 text-pink-300 text-sm font-sans">— Iván Cepeda, Encuentro en Santa Marta</footer>
    </blockquote>

    <!-- MARQUEE -->
    <div class="relative z-10 mb-12 bg-black/30 border-2 border-dashed border-pink-500/40 rounded-xl p-4 overflow-hidden">
      <p class="text-pink-200 font-mono text-sm sm:text-base" style="overflow-x:auto">
        <span class="inline-block mr-8">✊🏾 LA REVOLUCIÓN ÉTICA ES ANTIRRACISTA ✊🏾</span>
        <span class="inline-block mr-8">🌈 Diversidad no es amenaza, es riqueza 🌈</span>
        <span class="inline-block mr-8">🙋🏾‍♀️ Sin las mujeres no hay democracia 🙋🏾‍♀️</span>
        <span class="inline-block mr-8">🔥 La juventud es la chispa del cambio 🔥</span>
        <span class="inline-block mr-8">🪶 Los pueblos indígenas son autoridad ambiental 🪶</span>
      </p>
    </div>

    <!-- CIERRE -->
    <section class="relative z-10 mt-12 flex flex-col items-center text-center">
      <AsciiPattern lines={footerArt} colors={['text-fuchsia-300', 'text-sky-300', 'text-eje-equal', 'text-emerald-300']} wrapperClass="mb-6" textClass="text-[9px] xs:text-[10px] sm:text-xs md:text-sm" blockClass="gap-2" />
      <div class="text-6xl mb-4 hover:animate-spin cursor-default">✊🏾</div>
      <p class="text-xl font-bold text-pink-200 font-sans">
        "Colombia es una nación plural. <br/> La dignidad no se mendiga, se conquista."
      </p>
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 mt-8 bg-pink-700 hover:bg-pink-600 text-white px-6 py-3 rounded-full font-bold text-lg transition-all transform hover:scale-105 shadow-lg shadow-pink-500/30">
        🏠 Ir al Inicio
      </a>
    </section>

  </div>
</Layout>