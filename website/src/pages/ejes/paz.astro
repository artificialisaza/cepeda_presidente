---
import Layout from '../../layouts/Layout.astro';
import AsciiPattern from '../../components/AsciiPattern.astro';

const heroArt = [
  '  (o~o)   /\\___/\\   (o~o)   /\\___/\\  ',
  '   | |    \\  o  /    | |    \\  o  /  ',
  '  /| |\\    \\___/    /| |\\    \\___/   ',
  '  _| |_   < ~~~ >   _| |_   < ~~~ >  ',
  '  [~~~]    [~~~]     [~~~]    [~~~]   ',
];

const truthArt = [
  '  🌟  ✨  🌟  ✨  🌟  ✨  🌟  ✨  🌟  ',
  ' 💫  🔦  💫  🔦  💫  🔦  💫  🔦  💫 ',
  '  ✨  🌟  ✨  🌟  ✨  🌟  ✨  🌟  ✨  ',
];

const footerArt = [
  '  <(*)>  (o*o)  <(*)>  (o*o)  <(*)>  ',
  '   ~~~    ~~~    ~~~    ~~~    ~~~    ',
  '  ~^^^~  ~^^^~  ~^^^~  ~^^^~  ~^^^~  ',
];
---

<Layout title="🕊️ Paz y Anticorrupción - Iván Cepeda 2026" description="El Poder de la Verdad: Sistema Nacional contra la Macrocorrupción y la construcción de paz con justicia.">
  <div class="max-w-5xl mx-auto px-4 py-8 sm:py-12 relative overflow-hidden">

    <!-- Fondo Luz y Sombras -->
    <div class="absolute inset-0 pointer-events-none opacity-10 z-0" aria-hidden="true">
      <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-emerald-950 via-teal-950 to-amber-950"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 50% 20%, rgba(16,185,129,0.08) 0%, transparent 60%), radial-gradient(ellipse at 50% 80%, rgba(251,191,36,0.06) 0%, transparent 50%);"></div>
    </div>

    <AsciiPattern lines={heroArt} colors={['text-eje-peace', 'text-sky-300', 'text-emerald-200', 'text-pink-300', 'text-violet-300']} wrapperClass="mb-6" textClass="text-[9px] sm:text-xs md:text-sm" blockClass="gap-1" />

    <div class="mb-8 relative z-10">
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 text-emerald-300 hover:text-emerald-100 font-bold transition-colors bg-emerald-950/50 border border-emerald-500/30 px-4 py-2 rounded-full hover:bg-emerald-900/60 text-sm">
        🏠 ← Volver al Inicio
      </a>
    </div>

    <!-- HERO -->
    <header class="relative z-10 mb-16">
      <div class="relative bg-gradient-to-br from-emerald-900/70 via-teal-950/80 to-amber-900/70 border-4 border-emerald-400/40 rounded-3xl p-6 sm:p-10 shadow-[0_0_60px_rgba(16,185,129,0.15)] overflow-hidden">
        <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
          <span class="absolute top-3 left-[10%] text-3xl animate-bounce opacity-40" style="animation-duration:2s">🕊️</span>
          <span class="absolute top-8 right-[15%] text-4xl animate-pulse opacity-30" style="animation-duration:2.5s">🔍</span>
          <span class="absolute bottom-10 left-[20%] text-3xl animate-spin opacity-25" style="animation-duration:8s">⚖️</span>
          <span class="absolute top-1/3 right-[8%] text-5xl animate-bounce opacity-20" style="animation-duration:3s;animation-delay:0.5s">🐉</span>
          <span class="absolute bottom-8 right-[20%] text-2xl animate-pulse opacity-35" style="animation-duration:1.5s">🛡️</span>
        </div>

        <div class="relative">
          <h1 class="text-4xl sm:text-6xl md:text-7xl font-black uppercase mb-6 text-transparent bg-clip-text bg-gradient-to-r from-emerald-200 via-teal-300 to-amber-200 font-['Impact'] tracking-wider leading-tight">
            🕊️ Paz y Anticorrupción
          </h1>
          <p class="text-xl sm:text-2xl text-emerald-100 font-['Comic_Sans_MS',cursive] leading-relaxed max-w-3xl">
            La corrupción ya no es simple: es <strong class="text-white">Macrocorrupción</strong>, un dragón de cinco cabezas que saquea al país. 
            Cortarle las garras requiere Sistema Nacional, verdad de las víctimas y <strong class="text-amber-200">rebelión ciudadana</strong>.
            <span class="inline-block animate-pulse">🔍</span>
          </p>
        </div>
      </div>
    </header>

    <!-- STORYTELLING: La luz de la verdad -->
    <section class="relative z-10 mb-16 bg-gradient-to-r from-emerald-950/30 via-teal-950/40 to-amber-950/30 border-2 border-dashed border-emerald-500/30 rounded-3xl p-6 sm:p-8">
      <AsciiPattern lines={truthArt} colors={['text-amber-300', 'text-eje-peace', 'text-yellow-200']} wrapperClass="mb-6" textClass="text-[10px] sm:text-sm" blockClass="gap-1" />

      <h2 class="text-2xl sm:text-3xl font-bold text-emerald-200 mb-6 font-serif text-center">💫 El Poder de la Verdad: La Luz que Vence la Oscuridad</h2>

      <div class="flex flex-wrap justify-center items-center gap-3 sm:gap-5 text-2xl sm:text-4xl mb-8">
        <span class="hover:scale-150 transition-transform cursor-default" title="Verdad">💡</span>
        <span class="text-emerald-400 text-xl sm:text-2xl">→</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-bounce" style="animation-duration:2s" title="Víctimas">👵🏾</span>
        <span class="text-emerald-400 text-xl sm:text-2xl">→</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-pulse" style="animation-duration:2s" title="Justicia">⚖️</span>
        <span class="text-emerald-400 text-xl sm:text-2xl">→</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-spin" style="animation-duration:4s" title="Reparación">💎</span>
        <span class="text-emerald-400 text-xl sm:text-2xl">→</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-bounce" style="animation-duration:1.8s" title="No Repetición">🛡️</span>
        <span class="text-emerald-400 text-xl sm:text-2xl">→</span>
        <span class="hover:scale-150 transition-transform cursor-default animate-pulse" style="animation-duration:1.5s" title="Paz">🕊️</span>
      </div>

      <p class="text-emerald-50/80 text-center text-lg font-sans leading-relaxed max-w-2xl mx-auto">
        Las Madres Buscadoras, las Madres de Soacha, las víctimas del genocidio de la UP: 
        ellas detentan <strong class="text-white">el poder de la verdad</strong>. Ese poder es el primer motor de la Revolución Ética. 
        Sin verdad no hay justicia, sin justicia no hay paz.
      </p>
    </section>

    <!-- PORTAFOLIO DE SUBPÁGINAS -->
    <section class="relative z-10 mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-emerald-200 mb-8 text-center font-['Impact'] tracking-wider flex items-center justify-center gap-3">
        <span class="animate-bounce">🗡️</span> Frentes de la Revolución Ética <span class="animate-bounce">🛡️</span>
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6">
        <!-- Macrocorrupción -->
        <a href={import.meta.env.BASE_URL + 'ejes/paz/macrocorrupcion'} class="group block relative bg-gradient-to-b from-emerald-950/80 to-teal-950/90 border-3 border-emerald-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-emerald-500/20 hover:border-emerald-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🐉</div>
          <div class="text-5xl mb-3 group-hover:animate-bounce relative z-10">🐉</div>
          <h3 class="text-xl font-bold text-emerald-200 mb-2 font-['Impact']">El Dragón</h3>
          <p class="text-emerald-50/70 text-sm leading-relaxed">Sistema Nacional contra la Macrocorrupción. 5 pilares para desmantelar las redes.</p>
          <span class="inline-block mt-3 text-xs text-emerald-400 group-hover:text-emerald-200 transition-colors">⚔️ Explorar →</span>
        </a>

        <!-- Ética -->
        <a href={import.meta.env.BASE_URL + 'ejes/paz/etica'} class="group block relative bg-gradient-to-b from-orange-950/80 to-red-950/90 border-3 border-orange-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-orange-500/20 hover:border-orange-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🔥</div>
          <div class="text-5xl mb-3 group-hover:animate-pulse relative z-10">🔥</div>
          <h3 class="text-xl font-bold text-orange-200 mb-2 font-['Impact']">El Fuego</h3>
          <p class="text-orange-50/70 text-sm leading-relaxed">Revolución Ética: víctimas, Madres Buscadoras, memoria y educación para la paz.</p>
          <span class="inline-block mt-3 text-xs text-orange-400 group-hover:text-orange-200 transition-colors">🕯️ Explorar →</span>
        </a>

        <!-- Soberanía -->
        <a href={import.meta.env.BASE_URL + 'ejes/paz/soberania'} class="group block relative bg-gradient-to-b from-blue-950/80 to-indigo-950/90 border-3 border-blue-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-blue-500/20 hover:border-blue-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🌎</div>
          <div class="text-5xl mb-3 group-hover:animate-spin relative z-10" style="animation-duration:6s">🌎</div>
          <h3 class="text-xl font-bold text-blue-200 mb-2 font-['Impact']">Colombia en el Mundo</h3>
          <p class="text-blue-50/70 text-sm leading-relaxed">Política exterior soberana, nuevo paradigma antidrogas, protección de migrantes.</p>
          <span class="inline-block mt-3 text-xs text-blue-400 group-hover:text-blue-200 transition-colors">🌐 Explorar →</span>
        </a>

        <!-- Víctimas y Paz NUEVO -->
        <a href={import.meta.env.BASE_URL + 'ejes/paz/victimas-y-paz'} class="group block relative bg-gradient-to-b from-rose-950/80 to-pink-950/90 border-3 border-rose-400/30 rounded-2xl p-5 text-center shadow-lg hover:shadow-rose-500/20 hover:border-rose-400/60 hover:-translate-y-2 hover:scale-105 transition-all duration-300 overflow-hidden">
          <div class="absolute -top-4 -right-4 text-6xl opacity-20 group-hover:opacity-40 group-hover:scale-125 transition-all duration-500">🕯️</div>
          <div class="text-5xl mb-3 group-hover:animate-bounce relative z-10">🕯️</div>
          <h3 class="text-xl font-bold text-rose-200 mb-2 font-['Impact']">Víctimas y Paz Total 🆕</h3>
          <p class="text-rose-50/70 text-sm leading-relaxed">10.1M de víctimas, PDET, Acuerdo de Paz, protección de líderes y firmantes.</p>
          <span class="inline-block mt-3 text-xs text-rose-400 group-hover:text-rose-200 transition-colors">☮️ Explorar →</span>
        </a>
      </div>
    </section>

    <!-- DATOS DUROS -->
    <section class="relative z-10 mb-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6">
        <div class="bg-gradient-to-b from-red-950/60 to-orange-950/60 border-2 border-red-500/20 rounded-2xl p-6 text-center hover:border-red-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">🚨</div>
          <div class="text-4xl font-black text-red-300">94%</div>
          <p class="text-red-100/80 mt-2 text-sm">Impunidad en casos de corrupción</p>
        </div>
        <div class="bg-gradient-to-b from-amber-950/60 to-yellow-950/60 border-2 border-amber-500/20 rounded-2xl p-6 text-center hover:border-amber-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">💔</div>
          <div class="text-4xl font-black text-amber-300">10.1M</div>
          <p class="text-amber-100/80 mt-2 text-sm">Víctimas registradas del conflicto armado</p>
        </div>
        <div class="bg-gradient-to-b from-emerald-950/60 to-green-950/60 border-2 border-emerald-500/20 rounded-2xl p-6 text-center hover:border-emerald-400/60 transition-all group">
          <div class="text-5xl mb-3 group-hover:scale-110 transition-transform">💰</div>
          <div class="text-4xl font-black text-emerald-300">80B</div>
          <p class="text-emerald-100/80 mt-2 text-sm">Pesos gastados en 20 años en guerra antidrogas</p>
        </div>
      </div>
    </section>

    <!-- CITA ÉPICA -->
    <blockquote class="relative z-10 my-12 bg-gradient-to-r from-emerald-950/60 via-teal-950/40 to-amber-950/60 border-l-4 border-emerald-400 p-6 sm:p-8 rounded-r-2xl shadow-xl">
      <div class="absolute -top-4 -left-4 text-5xl">🕊️</div>
      <p class="text-xl sm:text-2xl italic text-white font-medium leading-relaxed font-serif">
        "No habrá paz completa sin verdad y sin justicia; no habrá paz verdadera sin reparación y garantías de no repetición. 
        <strong class="text-emerald-200">Cada meta del Acuerdo de Paz que alcancemos será un ladrillo más en la construcción de esa paz con justicia social.</strong>"
      </p>
      <footer class="mt-4 text-emerald-300 text-sm font-sans">— Iván Cepeda, Día Nacional por la Dignidad de las Víctimas de la UP</footer>
    </blockquote>

    <!-- MARQUEE -->
    <div class="relative z-10 mb-12 bg-black/30 border-2 border-dashed border-emerald-500/40 rounded-xl p-4 overflow-hidden">
      <p class="text-emerald-200 font-mono text-sm sm:text-base" style="overflow-x:auto">
        <span class="inline-block mr-8">🕊️ La paz es un derecho y un deber 🕊️</span>
        <span class="inline-block mr-8">🔍 Tolerancia cero con la macrocorrupción 🔍</span>
        <span class="inline-block mr-8">👵🏾 Las víctimas son el centro de la revolución ética 👵🏾</span>
        <span class="inline-block mr-8">⚖️ La decencia no es consigna: es requisito ⚖️</span>
        <span class="inline-block mr-8">🌎 América Latina debe seguir siendo zona de paz 🌎</span>
      </p>
    </div>

    <!-- CIERRE -->
    <section class="relative z-10 mt-12 flex flex-col items-center text-center">
      <AsciiPattern lines={footerArt} colors={['text-pink-300', 'text-violet-300', 'text-eje-peace', 'text-fuchsia-300']} wrapperClass="mb-6" textClass="text-[9px] xs:text-[10px] sm:text-xs md:text-sm" blockClass="gap-2" />
      <div class="text-6xl mb-4 hover:animate-spin cursor-default">🕊️</div>
      <p class="text-xl font-bold text-emerald-200 font-sans">
        "Solo con la verdad, la autocrítica y el compromiso colectivo, <br/> podremos avanzar hacia el país digno, justo y democrático."
      </p>
      <a href={import.meta.env.BASE_URL} class="inline-flex items-center gap-2 mt-8 bg-emerald-700 hover:bg-emerald-600 text-white px-6 py-3 rounded-full font-bold text-lg transition-all transform hover:scale-105 shadow-lg shadow-emerald-500/30">
        🏠 Ir al Inicio
      </a>
    </section>

  </div>
</Layout>